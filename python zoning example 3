#!/usr/bin/env python3
"""
Generates FC switch zone configuration from an Excel sheet using pandas.
- Prompts for a single VSAN
- Reads Excel file
- Maps columns to device-alias and member commands
- Supports multiple zones with row/range selection
- Outputs formatted config to a text file
"""

import pandas as pd
import os
import sys

def parse_row_indices(input_str, max_index):
    """Parses comma-separated integers and ranges (e.g., '0-2, 5, 7-9') into a sorted list."""
    indices = set()
    parts = input_str.split(',')
    
    for part in parts:
        part = part.strip()
        if not part:
            continue
            
        if '-' in part:
            range_parts = [p.strip() for p in part.split('-')]
            if len(range_parts) != 2:
                print("⚠️  Invalid range format. Use 'start-end'.")
                return None
            try:
                start, end = int(range_parts[0]), int(range_parts[1])
                if start > end:
                    print(f"⚠️  Invalid range: start ({start}) must be <= end ({end}).")
                    return None
                if start < 0 or end > max_index:
                    print(f"⚠️  Range out of bounds. Valid indices: 0 to {max_index}.")
                    return None
                indices.update(range(start, end + 1))
            except ValueError:
                print("⚠️  Invalid range format. Please use integers (e.g., 1-3).")
                return None
        else:
            try:
                idx = int(part)
                if idx < 0 or idx > max_index:
                    print(f"⚠️  Index {idx} out of bounds. Valid indices: 0 to {max_index}.")
                    return None
                indices.add(idx)
            except ValueError:
                print("⚠️  Invalid input. Please enter integers or ranges.")
                return None
                
    if not indices:
        print("⚠️  Please enter at least one row index or range.")
        return None
        
    return sorted(indices)

def main():
    # 1. Prompt for VSAN (single value for all zones)
    while True:
        vsan_input = input("Enter the VSAN number: ").strip()
        try:
            vsan = int(vsan_input)
            if 1 <= vsan <= 4094:
                break
            print("⚠️  VSAN must be between 1 and 4094. Please try again.")
        except ValueError:
            print("⚠️  Invalid input. Please enter a valid integer.")

    # 2. Prompt for Excel file path
    excel_path = input("Enter the path to the Excel file: ").strip()
    while not os.path.exists(excel_path):
        print("⚠️  File not found. Please check the path and try again.")
        excel_path = input("Enter the path to the Excel file: ").strip()

    # 3. Import Excel sheet using pandas
    try:
        df = pd.read_excel(excel_path, engine='openpyxl')
        if df.empty:
            print("❌ Excel file contains no data.")
            sys.exit(1)
    except Exception as e:
        print(f"❌ Error reading Excel file: {e}")
        sys.exit(1)

    # 4. Prompt for column names
    print(f"\n📋 Available columns in sheet: {list(df.columns)}")
    print("Enter column names for the 'member' command:")
    col_a_mem = input("  First value (colA): ").strip()
    col_b_mem = input("  Second value (colB): ").strip()
    col_d_mem = input("  Third value (colD): ").strip()

    print("Enter column names for the 'device-alias' command:")
    col_a_da = input("  First value (colA): ").strip()
    col_b_da = input("  Second value (colB): ").strip()
    col_c_da = input("  Third value (colC): ").strip()

    # Validate all columns exist in the DataFrame
    all_cols = [col_a_mem, col_b_mem, col_d_mem, col_a_da, col_b_da, col_c_da]
    missing = [c for c in all_cols if c not in df.columns]
    if missing:
        print(f"❌ Missing columns in Excel file: {missing}")
        sys.exit(1)

    # 5. Display DataFrame for row selection reference
    print("\n📊 Excel Data (Row indices shown on the left):")
    print(df.to_string())
    print(f"✅ Total data rows: {len(df)} (indices: 0 to {len(df)-1})\n")

    # 6. Collect zones and their members
    zone_configs = []
    while True:
        zone_name = input("Enter the zone name: ").strip()
        while not zone_name:
            print("⚠️  Zone name cannot be empty. Please try again.")
            zone_name = input("Enter the zone name: ").strip()

        while True:
            row_input = input(f"Enter row indices/ranges for '{zone_name}' (e.g., 0-2, 5, 7-9): ").strip()
            selected_indices = parse_row_indices(row_input, len(df) - 1)
            if selected_indices is not None:
                break

        # Format commands for each selected row
        members = []
        for idx in selected_indices:
            row = df.iloc[idx]
            
            # Device-alias command: device-alias name {col_a}_{col_b} pwwn {col_c}
            da_a = str(row[col_a_da]).strip() if pd.notna(row[col_a_da]) else ""
            da_b = str(row[col_b_da]).strip() if pd.notna(row[col_b_da]) else ""
            da_c = str(row[col_c_da]).strip() if pd.notna(row[col_c_da]) else ""
            da_line = f"device-alias name {da_a}_{da_b} pwwn {da_c}"
            
            # Member command: member device-alias join {col_a} {col_b} {col_d}
            mem_a = str(row[col_a_mem]).strip() if pd.notna(row[col_a_mem]) else ""
            mem_b = str(row[col_b_mem]).strip() if pd.notna(row[col_b_mem]) else ""
            mem_d = str(row[col_d_mem]).strip() if pd.notna(row[col_d_mem]) else ""
            mem_line = f"member device-alias join {mem_a} {mem_b} {mem_d}"
            
            members.append(da_line)
            members.append(mem_line)

        zone_configs.append({"name": zone_name, "members": members})

        # Ask if another zone is needed
        while True:
            another = input("\nDo you want to add another zone? (yes/no): ").strip().lower()
            if another in ('yes', 'no', 'y', 'n'):
                break
            print("⚠️  Please enter 'yes' or 'no'.")
        if another in ('no', 'n'):
            break

    # 7. Write all zones to output file
    output_file = "zone_vsan_output.txt"
    try:
        with open(output_file, "w", encoding="utf-8") as f:
            f.write(f"VSAN: {vsan}\n")
            f.write("=" * 60 + "\n")
            
            for zone in zone_configs:
                f.write(f"Zone Name: {zone['name']}\n")
                for member in zone['members']:
                    f.write(f"{member}\n")
                f.write("-" * 60 + "\n")
                
        print(f"✅ Successfully saved {len(zone_configs)} zone(s) to {output_file}")
    except IOError as e:
        print(f"❌ Error writing to file: {e}")

if __name__ == "__main__":
    main()
